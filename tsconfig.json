{
  "compilerOptions": {
    "jsx": "react-jsx",
    /* Paths */
    "baseUrl": ".",  //절대경로 디렉터리 설정
    "paths": {
      "@/*": ["./src/*"],
      "components/*":["./src/components/*"]
    },
    "moduleResolution": "bundler",
    "module": "esnext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"] // import.meta 사용 가능하도록 라이브러리 추가
  },
  "include": ["src"]
}